# Flowgent Environment Configuration
# Copy to .env and fill in your values

# Database
POSTGRES_USER=flowgent
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=flowgent
DATABASE_URL=postgresql://flowgent:change-me-in-production@localhost:5432/flowgent

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate strong random strings!)
JWT_SECRET=generate-a-strong-secret-here
JWT_REFRESH_SECRET=generate-another-strong-secret-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# API
PORT=4000
NODE_ENV=development

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:4000
API_URL=http://backend:4000

# Coolify (set these in Coolify dashboard)
# COOLIFY_DOMAIN=flowgent.yourdomain.com
